PORT=18080
HOST_PORT=18080
PUBLIC_BASE_URL=https://pay-adapter.example.com

# Lantu Pay side. Configure these same values as newapi's ePay pid/key.
LANTU_API_BASE=https://api.ltzf.cn
LANTU_MCH_ID=1230000109
LANTU_KEY=change_me_lantu_key

# wxpay: native | h5 | jump_h5 | miniprogram_h5
LANTU_WXPAY_MODE=native

# alipay: native | h5
LANTU_ALIPAY_MODE=native

# Optional passthrough developer_appid for Lantu.
LANTU_DEVELOPER_APPID=

# Request timeout in milliseconds.
HTTP_TIMEOUT_MS=15000
